# Copy to .env and fill in. Never commit real .env.

# Database (dev: SQLite). Production: PostgreSQL recommended.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/quizdb
DATABASE_URL=sqlite:///./quiz_platform.db

# JWT signing — MUST be a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret-key

ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: AI question generation (Gemini)
GEMINI_API_KEY=

# Browser origins (if you tighten CORS in code later)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
